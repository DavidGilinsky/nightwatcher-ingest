#!/bin/sh
# nightwatcher-ingest postrm: reload systemd; on purge drop config, account, and
# the debconf answers.
set -e

if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || true
fi

case "$1" in
  purge)
    rm -f /etc/nwingest/nwingest.yaml /etc/nwingest/nwingest.env
    rmdir /etc/nwingest 2>/dev/null || true
    if getent passwd nwingest >/dev/null 2>&1; then
        deluser --system nwingest >/dev/null 2>&1 || true
    fi
    if [ -e /usr/share/debconf/confmodule ]; then
        . /usr/share/debconf/confmodule
        db_purge || true
    fi
    ;;
esac

exit 0
