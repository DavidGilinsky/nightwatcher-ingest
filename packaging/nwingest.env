# EnvironmentFile for the nwingest service. Secrets live here (mode 0640),
# not in nwingest.yaml or the unit file. systemd reads this via the unit's
# `EnvironmentFile=-/etc/nwingest/nwingest.env`.
#
# Password for the NightWatcher database. Only needed when `sqm.enabled` or
# `extension.register` is true in nwingest.yaml. Uncomment and set:
#NWDB_PASSWORD=
